          <h2 id="radar-heading" class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight" style="color: hsl(230 25% 10%);">
            Управленческий радар: <span style="color: hsl(248 80% 71%);">7 направлений</span>
          </h2>
          <p class="mt-6 text-base md:text-lg leading-relaxed" style="color: hsl(240 8% 42%);">
            Два замера — в начале и в конце программы. Вы сможете увидеть изменения и динамику по всем 7 направлениям.
          </p>
        </div>
        <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
          <!-- Radar card -->
          <div class="card-dark rounded-3xl p-4 md:p-6" aria-hidden="true">
            <svg width="100%" viewBox="-180 -180 360 360" xmlns="http://www.w3.org/2000/svg" style="max-height: 460px;">
              {[1,2,3,4].map(i => (
                <polygon points={gridPoints(i, 7, 140)} fill="none" stroke="hsl(248 80% 71% / 0.4)" stroke-width="1" stroke-dasharray="4 4"/>
              ))}
              {Array.from({length: 7}, (_, k) => {
                const angle = (k * 2 * Math.PI / 7) - Math.PI / 2;
                return <line x1="0" y1="0" x2={Math.cos(angle)*140} y2={Math.sin(angle)*140} stroke="hsl(248 80% 71% / 0.2)" stroke-width="1" />;
              })}
              <polygon
                points={radarPoints([0.8, 0.7, 0.8, 0.8, 0.8, 0.7, 0.8], 140)}
                fill="hsl(248 80% 71% / 0.15)"
                stroke="hsl(248 80% 71%)"
                stroke-width="2"
                style="filter: drop-shadow(0 0 6px hsl(248 80% 71% / 0.5));"
              />
              {radarDirections.map((label, k) => {
                const angle = (k * 2 * Math.PI / 7) - Math.PI / 2;
                const r = 162;
                return (
                  <text
                    x={Math.cos(angle) * r}
                    y={Math.sin(angle) * r}
