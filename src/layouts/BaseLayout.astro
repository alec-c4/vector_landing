---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Вектор — Школа управления ветеринарным бизнесом',
  description = 'Первая школа управления для профессионалов ветеринарного бизнеса. Эффективно управляйте финансами и людьми, развивайте бизнес и масштабируйтесь.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Вектор" />
    <meta property="og:title" content="Вектор — Школа управления ветеринарным бизнесом" />
    <meta property="og:description" content="Первая школа управления для профессионалов ветеринарного бизнеса." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://vectorvet.ru/" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:rounded">
      Перейти к основному содержанию
    </a>

    <Nav />

    <main id="main-content">
      <slot />
    </main>

    <Footer />

    <script>
      import '../scripts/landing.ts';

      if (window.matchMedia('(min-width: 768px)').matches) {
        void import('../scripts/sphere.ts');
      }
    </script>
  </body>
</html>
