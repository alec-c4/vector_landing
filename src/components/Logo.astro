---
interface Props {
  class?: string;
  href?: string;
  /** `light` — белый логотип для тёмного фона; `dark` — тёмный для светлого фона */
  variant?: 'light' | 'dark';
}

const {
  class: className = 'h-8',
  href = '#',
  variant = 'light',
} = Astro.props;

const src = variant === 'light' ? '/logo-light.png' : '/logo-dark.png';
const width = variant === 'light' ? 180 : 120;
const height = variant === 'light' ? 64 : 88;
const alt = 'ВЕКТОР — ветеринарная школа управления';
---

<a href={href} aria-label="ВЕКТОР — на главную" class:list={['inline-flex items-center', className]}>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    class="h-full w-auto object-contain object-left"
    decoding="async"
  />
</a>
