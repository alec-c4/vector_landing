---
interface Props {
  class?: string;
  href?: string;
  /** `light` — для тёмного фона; `dark` — для светлого фона */
  variant?: 'light' | 'dark';
  /** Компактный wordmark для шапки (logo.png) */
  compact?: boolean;
}

const {
  class: className = 'h-8',
  href = '#',
  variant = 'light',
  compact = false,
} = Astro.props;

const src = compact
  ? '/logo.png'
  : variant === 'light'
    ? '/logo-light.png'
    : '/logo-dark.png';

const width = compact ? 154 : variant === 'light' ? 180 : 120;
const height = compact ? 32 : variant === 'light' ? 64 : 88;
const alt = 'ВЕКТОР — ветеринарная школа управления';
---

<a href={href} aria-label="ВЕКТОР — на главную" class:list={['inline-flex items-center', className]}>
  <img
    src={src}
    alt={alt}
    width={width}
    height={height}
    class="h-full w-auto object-contain object-left"
    decoding="async"
  />
</a>
