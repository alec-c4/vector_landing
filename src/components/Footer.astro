---
import Logo from './Logo.astro';
import navLinks from '../data/nav';
---

<footer class="py-16 border-t border-white/5" style="background: hsl(240 8% 11%);">
  <div class="container mx-auto">
    <div class="grid md:grid-cols-3 gap-10">
      <div>
        <Logo class="h-10 mb-4" />
        <p class="text-sm" style="color: hsl(240 20% 70%);">Первая школа управления для профессионалов ветеринарного бизнеса</p>
      </div>
      <nav aria-label="Навигация в подвале">
        <h3 class="font-display font-semibold text-white mb-4">Навигация</h3>
        <ul class="flex flex-col gap-2 text-sm">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href} class="transition-colors hover:text-white" style="color: hsl(240 20% 70%);">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
      <div>
        <h3 class="font-display font-semibold text-white mb-4">Контакты</h3>
        <ul class="flex flex-col gap-2 text-sm">
          <li><a href="mailto:info@vectorvet.ru" class="hover:text-white transition-colors" style="color: hsl(240 20% 70%);">info@vectorvet.ru</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-12 pt-8 border-t border-white/5 text-center text-xs" style="color: hsl(240 15% 65%);">
      © 2026 ВЕКТОР. Все права защищены.
    </div>
  </div>
</footer>
