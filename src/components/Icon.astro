---
import type { FeatureIconName } from '../types/content';

interface Props {
  name: FeatureIconName;
  class?: string;
}

const { name, class: className = '' } = Astro.props;
const attrs = {
  width: '24',
  height: '24',
  viewBox: '0 0 24 24',
  fill: 'none',
  stroke: 'currentColor',
  'stroke-width': '2',
  'stroke-linecap': 'round',
  'stroke-linejoin': 'round',
  'aria-hidden': 'true',
  class: className,
};
---

