---
import ModelChain from '../ModelChain.astro';
import RadarChart from '../RadarChart.astro';
import { analysisModels } from '../../data/models';
---

<section class="py-16 md:py-24 bg-white relative overflow-hidden" aria-labelledby="models-heading">
  <div class="absolute top-1/3 -left-32 w-96 h-96 rounded-full pointer-events-none model-section-glow"></div>
  <div class="container mx-auto relative">
    <div class="max-w-3xl mb-14">
      <span class="badge-light">Три перспективы</span>
      <h2 id="models-heading" class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight text-foreground">
        Курс даёт <span class="text-accent">три модели анализа</span> — каждая отвечает на свой вопрос
      </h2>
      <p class="mt-6 text-base md:text-lg leading-relaxed max-w-3xl text-muted-foreground">
        Все три модели анализа вводятся с первого дня обучения и проходят через всю программу. К завершению курса вы формируете системный подход к анализу и управлению клиникой через три управленческие модели.
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-4 md:gap-6 items-stretch">
      {
        analysisModels.map((model) => (
          <article class="model-card card-dark rounded-3xl p-6 md:p-8 flex flex-col">
            <div class="text-center">
              <span class="badge-primary-text">{model.num}</span>
            </div>
            <h3 class="font-display text-xl md:text-2xl font-bold text-white text-center mb-2">
              {model.title}
            </h3>
            <p class="text-center text-sm md:text-base italic mb-6 text-accent-soft">
              {model.question}
            </p>
            <div class="model-card-visual flex-1 flex flex-col items-center justify-center min-h-0">
              {model.type === 'radar' && <RadarChart labels={model.labels} size={280} chartId="models-radar" />}
              {model.type === 'chain' && <ModelChain labels={model.labels} />}
            </div>
            <p class="text-sm md:text-base leading-relaxed mt-6 text-hero-muted">{model.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
