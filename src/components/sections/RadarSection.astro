---
import RadarChart from '../RadarChart.astro';
import { radarModules } from '../../data/radar';
import { radarDirections } from '../../lib/radar';
---

<section class="py-16 md:py-24 bg-white relative overflow-hidden" aria-labelledby="radar-heading">
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 w-[40rem] h-[40rem] rounded-full pointer-events-none" style="background: hsl(248 80% 71% / 0.1); filter: blur(80px);"></div>
  <div class="container mx-auto relative">
    <div class="max-w-3xl mb-14">
      <span class="badge-light">Ключевой инструмент</span>
      <h2 id="radar-heading" class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight" style="color: hsl(230 25% 10%);">
        Управленческий радар: <span style="color: hsl(248 80% 71%);">7 направлений</span>
      </h2>
      <p class="mt-6 text-base md:text-lg leading-relaxed" style="color: hsl(240 8% 42%);">
        Два замера — в начале и в конце программы. Вы сможете увидеть изменения и динамику по всем 7 направлениям.
      </p>
    </div>
    <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-center">
      <div class="card-dark rounded-3xl p-4 md:p-6 flex items-center justify-center" aria-hidden="true">
        <RadarChart labels={[...radarDirections]} size={460} chartId="section-radar" />
      </div>
      <div class="flex flex-col gap-3">
        {
          radarModules.map((label) => (
            <div class="card-dark rounded-2xl px-5 py-4 flex items-center gap-3">
              <span class="w-2 h-2 rounded-full flex-shrink-0" style="background: hsl(248 80% 71%);"></span>
              <span class="text-sm md:text-base text-white">{label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
