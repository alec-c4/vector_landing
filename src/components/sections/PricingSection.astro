---
import { pricingFeatures } from '../../data/metrics';
---

<section id="pricing" class="py-16 md:py-24 bg-white" aria-labelledby="pricing-heading">
  <div class="container mx-auto">
    <div class="text-center mb-16">
      <span class="badge-border">Тариф</span>
      <h2 id="pricing-heading" class="font-display text-3xl md:text-4xl font-bold" style="color: hsl(230 25% 10%);">
        Единый <span class="text-gradient">формат участия</span>
      </h2>
    </div>
    <div class="max-w-2xl mx-auto rounded-2xl p-8 sm:p-10 flex flex-col shadow-glow border" style="background: hsl(240 30% 6%); border-color: hsl(248 80% 71% / 0.3); color: white;" data-reveal>
      <span class="inline-block self-start px-3 py-1 rounded-full text-xs font-medium mb-4" style="background: hsl(248 80% 71% / 0.2); color: hsl(248 80% 71%);">Поток сентябрь 2026</span>
      <h3 class="font-display font-bold text-2xl mb-1 text-white">Флагманский курс «Вектор»</h3>
      <p class="font-display font-bold text-4xl mb-8 text-white">149 000 ₽</p>
      <ul class="flex flex-col gap-3 mb-8 flex-1" aria-label="Что входит в курс">
        {
          pricingFeatures.map((item) => (
            <li class="flex items-center gap-2 text-sm">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="hsl(248 80% 71%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              <span style="color: hsl(240 20% 85%);">{item}</span>
            </li>
          ))
        }
      </ul>
      <a
        href="#contacts"
        class="block w-full text-center font-semibold py-3.5 rounded-full text-white text-sm transition-opacity hover:opacity-90"
        style="background: hsl(248 75% 52%);"
      >Забронировать место</a>
    </div>
  </div>
</section>
