<section id="contacts" class="py-16 md:py-24" style="background: hsl(240 10% 96%);" aria-labelledby="contact-heading">
  <div class="container mx-auto max-w-xl">
    <div class="text-center mb-10">
      <span class="badge-border">Свяжитесь с нами</span>
      <h2 id="contact-heading" class="font-display text-3xl md:text-4xl font-bold" style="color: hsl(230 25% 10%);">
        Остались <span class="text-gradient">вопросы?</span>
      </h2>
    </div>
    <form
      id="contact-form"
      class="bg-white rounded-2xl p-8 border flex flex-col gap-5"
      data-reveal
      aria-label="Форма обратной связи"
      style="border-color: hsl(240 10% 90%); box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.07);"
    >
      <div id="contact-form-status" class="hidden rounded-xl px-4 py-3 text-sm" role="status" aria-live="polite"></div>
      <div class="sr-only" aria-hidden="true">
        <label for="contact-website">Сайт</label>
        <input id="contact-website" type="text" name="website" tabindex="-1" autocomplete="off" />
      </div>
      <div>
        <label for="contact-name" class="block text-sm font-medium mb-1.5" style="color: hsl(230 25% 10%);">Имя</label>
        <input
          id="contact-name"
          type="text"
          name="name"
          required
          placeholder="Ваше имя"
          class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition-shadow"
          style="border-color: hsl(240 10% 90%); color: hsl(230 25% 10%);"
        />
      </div>
      <div>
        <label for="contact-email" class="block text-sm font-medium mb-1.5" style="color: hsl(230 25% 10%);">Email</label>
        <input
          id="contact-email"
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition-shadow"
          style="border-color: hsl(240 10% 90%); color: hsl(230 25% 10%);"
        />
      </div>
      <div>
        <label for="contact-message" class="block text-sm font-medium mb-1.5" style="color: hsl(230 25% 10%);">Сообщение</label>
        <textarea
          id="contact-message"
          name="message"
          rows="4"
          placeholder="Ваш вопрос или сообщение"
          class="w-full px-4 py-3 rounded-xl border text-sm outline-none transition-shadow resize-none"
          style="border-color: hsl(240 10% 90%); color: hsl(230 25% 10%);"
        ></textarea>
      </div>
      <button
        id="contact-submit"
        type="submit"
        class="w-full inline-flex items-center justify-center gap-2 py-3.5 rounded-full font-semibold text-white text-sm transition-opacity hover:opacity-90 disabled:opacity-60 disabled:cursor-not-allowed"
        style="background: hsl(248 75% 52%);"
      >
        Отправить
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
      </button>
    </form>
  </div>
</section>
