---
import modules from '../../data/modules';
---

<section id="program" class="py-16 md:py-24 bg-white" aria-labelledby="curriculum-heading">
  <div class="container mx-auto">
    <span class="badge-light">Программа обучения</span>
    <h2 id="curriculum-heading" class="font-display text-3xl md:text-4xl font-bold mb-2" style="color: hsl(230 25% 10%);">
      Флагманский курс «Вектор»
    </h2>
    <p class="text-sm mb-10" style="color: hsl(240 8% 42%);">
      3 офлайн-встречи · 2 месяца обучения · 7 практических домашних задания · 13 тестов
    </p>
    <div class="flex gap-2 overflow-x-auto pb-2 mb-8" role="tablist" aria-label="Модули программы">
      {
        modules.map((m, i) => (
          <button
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            aria-controls={`module-panel-${i}`}
            id={`module-tab-${i}`}
            data-tab-index={i}
            class="module-tab flex-shrink-0 px-4 py-2 rounded-full text-sm font-medium transition-colors"
            style={i === 0
              ? 'background: hsl(248 75% 52%); color: white;'
              : 'background: hsl(240 10% 94%); color: hsl(240 8% 42%);'}
          >Модуль {m.num}</button>
        ))
      }
    </div>
    <div>
      {
        modules.map((m, i) => (
          <div
            role="tabpanel"
            id={`module-panel-${i}`}
            aria-labelledby={`module-tab-${i}`}
            class={`module-panel rounded-2xl p-8 border${i !== 0 ? ' hidden' : ''}`}
            style="border-color: hsl(240 10% 90%);"
          >
            <div class="flex flex-wrap items-start justify-between gap-4 mb-4">
              <div>
                <p class="number-badge-light mb-1">Модуль {m.num}</p>
                <h3 class="font-display font-bold text-2xl" style="color: hsl(230 25% 10%);">{m.title}</h3>
              </div>
              <span class="text-xs font-medium px-3 py-1 rounded-full" style="background: hsl(248 85% 96%); color: hsl(248 60% 35%);">{m.duration}</span>
            </div>
            <p class="text-sm mb-6" style="color: hsl(240 8% 42%);">{m.desc}</p>
            <ul class="flex flex-col gap-2">
              {
                m.topics.map((topic) => (
                  <li class="flex gap-2 text-sm" style="color: hsl(230 25% 10%);">
                    <span class="flex-shrink-0" style="color: hsl(248 80% 65%);">•</span>
                    <span>{topic}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
