---
import faqs from '../../data/faqs';
---

<section class="py-16 md:py-24" style="background: hsl(240 30% 6%);" aria-labelledby="faq-heading">
  <div class="container mx-auto max-w-3xl">
    <div class="text-center mb-12">
      <span class="badge-dark">FAQ</span>
      <h2 id="faq-heading" class="font-display text-3xl md:text-4xl font-bold text-white">
        Частые <span class="text-gradient">вопросы</span>
      </h2>
    </div>
    <div class="flex flex-col gap-3">
      {
        faqs.map((faq, i) => (
          <div class="card-dark rounded-2xl border overflow-hidden" style="border-color: hsl(248 80% 71% / 0.1);">
            <h3 class="m-0">
              <button
                class="faq-btn w-full flex items-center justify-between gap-4 p-5 text-left font-display font-bold text-base text-white"
                aria-expanded="false"
                aria-controls={`faq-answer-${i}`}
                id={`faq-btn-${i}`}
                type="button"
              >
                <span>{faq.q}</span>
                <svg class="faq-icon flex-shrink-0 transition-transform duration-200" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
                  <path d="M5 7.5L10 12.5L15 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </h3>
            <div id={`faq-answer-${i}`} role="region" aria-labelledby={`faq-btn-${i}`} class="faq-answer hidden px-5 pb-5">
              <p class="text-sm leading-relaxed whitespace-pre-line" style="color: hsl(240 20% 75%);">{faq.a}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
