---
import Icon from '../Icon.astro';
import trustFeatures from '../../data/trustFeatures';
---

<section class="py-16 md:py-24 bg-white relative overflow-hidden" aria-labelledby="trust-heading">
  <div class="absolute top-1/3 -right-40 w-[28rem] h-[28rem] rounded-full pointer-events-none" style="background: hsl(248 80% 71% / 0.1); filter: blur(80px);"></div>
  <div class="absolute -bottom-32 -left-32 w-96 h-96 rounded-full pointer-events-none" style="background: hsl(248 80% 71% / 0.05); filter: blur(80px);"></div>
  <div class="container mx-auto relative">
    <div class="grid lg:grid-cols-2 gap-6 md:gap-10 lg:gap-16 mb-8 md:mb-14 max-w-6xl">
      <div>
        <span class="badge-light">Наш опыт</span>
        <h2 id="trust-heading" class="font-display text-3xl md:text-4xl lg:text-5xl font-bold leading-tight" style="color: hsl(230 25% 10%);">
          Почему нам <span style="color: hsl(248 80% 71%);">доверяют</span>
        </h2>
      </div>
      <div class="text-base md:text-lg leading-relaxed lg:pt-4" style="color: hsl(240 8% 42%);">
        ВЕКТОР создаётся лидерами ветеринарной индустрии и командой <strong style="color: hsl(230 25% 10%);">Национальной Ветеринарной Конференции (NVC)</strong>, которая много лет развивает крупнейшую образовательную среду ветеринарного рынка и работает с запросами владельцев клиник, управленцев и врачей по всей стране.
      </div>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 md:gap-6">
      {
        trustFeatures.map((item) => (
          <div class="trust-card card-light rounded-3xl p-5 md:p-8 flex flex-col" data-reveal>
            <div class="flex items-start gap-3 md:gap-4 mb-3 md:mb-5">
              <div class="icon-box-light">
                <Icon name={item.icon} />
              </div>
              <div class="text-xs pt-3 opacity-60" style="color: hsl(240 8% 42%);">({item.num})</div>
            </div>
            <h3 class="font-display text-lg md:text-2xl font-bold mb-2 md:mb-3 leading-snug" style="color: hsl(230 25% 10%);">{item.title}</h3>
            <p class="text-sm md:text-base leading-relaxed" style="color: hsl(240 8% 42%);">{item.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
